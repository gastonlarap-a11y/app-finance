# Environment configuration for App Finance
# Copy to .env (gitignored) and adjust. These override config.toml keys.

DISPLAY_NAME=App Finance
LOG_LEVEL=info
DB_FILENAME=app-finance.db
DATA_STRATEGY=osstandard
# DB_DATA_DIR=/Users/you/Documents/bases de datos/sqlite
# BACKUP_LOCAL_DIR=

# Optional: bake your Google OAuth client so users just click "Conectar".
# (Or paste it in the app's Settings tab.)
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
