<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="app-finance"
        Arguments=""
        InstallLocation="C:\Program Files\App Finance\App Finance">
    </Installer>
    <PackageInformation
        PackageName="App Finance"
        PackageDisplayName="App Finance"
        PublisherName="CN=App Finance"
        PublisherDisplayName="App Finance"
        Version="0.1.0.0"
        PackageDescription="Personal finance desktop app">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="com.gastonlarap.app-finance"
                Description="Personal finance desktop app"
                DisplayName="App Finance"
                ExecutableName="app-finance"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>App Finance</DisplayName>
            <PublisherDisplayName>App Finance</PublisherDisplayName>
            <Description>Personal finance desktop app</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="app-finance.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
