{
  "permissions": {
    "allow": [
      "Bash(task build:*)",
      "Bash(wails3 build:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/git-safety.sh\""
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "go@gaston-plugins": true,
    "ux@gaston-plugins": true
  }
}
