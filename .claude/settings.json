{
  "permissions": {
    "allow": [
      "Bash(task build:*)",
      "Bash(wails3 build:*)",
      "Bash(wails3 generate:*)",
      "Bash(wails3 doctor)",
      "Bash(go build:*)",
      "Bash(go vet:*)",
      "Bash(go test:*)"
    ],
    "ask": [
      "Bash(git push:*)"
    ],
    "deny": [
      "Read(./config.toml)",
      "Read(**/.env)",
      "Read(**/*.env)",
      "Read(**/secrets.env)",
      "Read(**/google-token.json)",
      "Read(**/*.local.go)",
      "Read(./frontend/bindings/**)",
      "Read(./frontend/dist/**)",
      "Read(./bin/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/git-safety.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "if": "Edit(*.go)",
            "command": "gofmt -w \"$(cat | jq -r '.tool_input.file_path')\"",
            "timeout": 30
          },
          {
            "type": "command",
            "if": "Write(*.go)",
            "command": "gofmt -w \"$(cat | jq -r '.tool_input.file_path')\"",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "go@dev-plugins": true,
    "ux@dev-plugins": true,
    "gopls-lsp@claude-plugins-official": true
  }
}
